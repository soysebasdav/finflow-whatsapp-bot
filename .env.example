# Local solamente. En Railway NO necesitas crear PORT; Railway lo inyecta automáticamente.
PORT=3100

# Cambia esto por un token largo y secreto en Railway y en la app PHP.
BOT_API_TOKEN=cambia_este_token_largo_y_seguro

# Identificador de la sesión de WhatsApp Web.
WWEBJS_CLIENT_ID=finflow-main

# En Railway usa un volumen persistente montado en /data.
WWEBJS_DATA_PATH=/data/.wwebjs_auth

HEADLESS=true
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
